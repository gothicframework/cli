package main

import (
	gothic "github.com/gothicframework/core/config"
)

var Config = gothic.Config{
	ProjectName: "{{.ProjectName}}",
	// TofuBinaryPath: "", // optional: absolute path to tofu binary override
	// DockerfilePath: "", // optional: absolute path to custom Dockerfile
	// WasmBinary:     "", // optional: absolute path to tinygo binary override
	// TailwindBinary: "", // optional: absolute path to tailwind binary override
	OptimizeImages: gothic.OptimizeImagesConfig{
		LowResolutionRate: 20,
	},
	// Runtime configures the router that main.go hands to gothicServer.Middleware.
	// The zero value is the default below, so you can delete this block entirely.
	//
	//   CacheStrategy: production cache backend.
	//     CACHE_CONTROL_HEADERS (default) | IN_MEMORY | REDIS | LOCAL_FILES
	//   LocalDevelopmentCache: cache backend used during hot reload.
	//     IN_MEMORY (default) | REDIS | LOCAL_FILES
	//   ServeStaticFiles: where /public/* is served from.
	//     CDN (default): your CDN/object store serves it in prod; disk only in dev.
	//     DISK: the app serves it from ./public in every env (ship public/ with the binary).
	//     EMBEDDED: baked into the binary via go:embed (single self-contained binary).
	//   CacheConfig: optional backend settings (Redis URL, compression, ...).
	Runtime: gothic.RuntimeConfig{
		CacheStrategy:         gothic.CACHE_CONTROL_HEADERS,
		LocalDevelopmentCache: gothic.IN_MEMORY,
		ServeStaticFiles:      gothic.CDN,
	},
	Deploy: &gothic.DeployConfig{
		// Provider selects the cloud to deploy to. v3 ships AWS only.
		Provider: gothic.AWS,
		Providers: gothic.Providers{
			AWS: gothic.AWSProvider{
				ServerMemory:  512,
				ServerTimeout: 30,
				Region:        "us-east-1",
				Profile:       "default",
				// CDN tunes how CloudFront caches + forwards the dynamic (server) requests:
				// which query params, cookies and request headers reach your app AND vary
				// its cache. The default (this block omitted) keeps ALL query params — so
				// ?lang=PT and ?lang=ENG render and cache separately — and forwards no
				// cookies or headers. Set each field with the gothic.Allow* builders:
				//   gothic.AllowAll()                      — every value (the default)
				//   gothic.AllowNone()                     — none
				//   gothic.Allow("a", "b")                 — only these
				//   gothic.AllowAllExcept("utm_source")    — all except these
				//
				// Headers accept only AllowNone() or Allow(...). ⚠ Never Allow the "Host"
				// or "Authorization" header: CloudFront signs the Lambda Function URL
				// (SigV4 via Origin Access Control) against the function URL's own host, so
				// forwarding either header breaks the signature and returns HTTP 403.
				// CDN: gothic.CDNConfig{
				// 	QueryParams: gothic.AllowAll(), // default
				// 	Cookies:     gothic.Allow("session"),
				// 	Headers:     gothic.Allow("CloudFront-Viewer-Country"),
				// },
				Stages: map[string]gothic.Stage{
					"dev": {
						// Custom domain (optional). These 4 fields are source-aware like ENV:
						// use gothic.Env("literal"), gothic.SSMParam("/path") or
						// gothic.SecretsManager("/path") so a domain or ARN is pulled at
						// deploy time instead of being committed in plain text.
						//
						// Set CustomDomain + HostedZoneId and Gothic creates + DNS-validates
						// the ACM certificate for you, in us-east-1, regardless of the stack's
						// Region — no CertificateArn needed. Provide CertificateArn only to
						// reuse an existing us-east-1 certificate instead.
						// CustomDomain: gothic.SSMParam("/myapp/dev/domain"),
						// HostedZoneId: gothic.SSMParam("/myapp/dev/hosted-zone-id"),
						// CertificateArn: gothic.SecretsManager("/myapp/dev/cert-arn"), // optional (BYO)
						// WafArn:         gothic.SSMParam("/myapp/dev/waf-arn"),         // optional
						ENV: map[string]gothic.EnvValue{
							// "PORT":     gothic.Env("8080"),
							// "DB_URL":   gothic.SSMParam("/myapp/dev/db-url"),
							// A Secrets Manager secret is usually a JSON object; use .Get to pull a
							// single field so the env var receives the value, not the whole JSON:
							// "API_KEY":  gothic.SecretsManager("/myapp/dev/api-key").Get("secret-key"),
							// Omit .Get when the secret/parameter stores a plain string:
							// "API_KEY":  gothic.SecretsManager("/myapp/dev/api-key"),
						},
					},
				},
			},
		},
	},
}

