{
  "resource": {
    "aws_ecr_repository": {
      "main": {
        "name": "${var.project_name}-${var.stage}-${var.suffix}",
        "image_tag_mutability": "MUTABLE",
        "force_delete": true,
        "image_scanning_configuration": {
          "scan_on_push": true
        }
      }
    },
    "aws_ecr_lifecycle_policy": {
      "main": {
        "repository": "${aws_ecr_repository.main.name}",
        "policy": "{\"rules\":[{\"rulePriority\":1,\"description\":\"Keep last 5 images\",\"selection\":{\"tagStatus\":\"any\",\"countType\":\"imageCountMoreThan\",\"countNumber\":5},\"action\":{\"type\":\"expire\"}}]}"
      }
    },
    "aws_lambda_function": {
      "main": {
        "function_name": "${var.lambda_name}",
        "package_type": "Image",
        "image_uri": "${var.ecr_image_uri}",
        "role": "${aws_iam_role.lambda.arn}",
        "memory_size": "${var.server_memory}",
        "timeout": "${var.server_timeout}",
        "environment": {
          "variables": "${local.env_vars}"
        }
      }
    },
    "aws_iam_role": {
      "lambda": {
        "name": "${var.lambda_name}-role",
        "assume_role_policy": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Action\":\"sts:AssumeRole\",\"Effect\":\"Allow\",\"Principal\":{\"Service\":\"lambda.amazonaws.com\"}}]}"
      }
    },
    "aws_iam_role_policy_attachment": {
      "lambda_basic": {
        "role": "${aws_iam_role.lambda.name}",
        "policy_arn": "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
      }
    },
    "aws_lambda_function_url": {
      "main": {
        "function_name": "${aws_lambda_function.main.function_name}",
        "authorization_type": "AWS_IAM"
      }
    },
    "aws_lambda_permission": {
      "cloudfront": {
        "statement_id": "AllowCloudFrontInvoke",
        "action": "lambda:InvokeFunctionUrl",
        "function_name": "${aws_lambda_function.main.function_name}",
        "principal": "cloudfront.amazonaws.com",
        "function_url_auth_type": "AWS_IAM",
        "source_arn": "${aws_cloudfront_distribution.main.arn}"
      },
      "cloudfront_invoke": {
        "statement_id": "AllowCloudFrontInvokeFunction",
        "action": "lambda:InvokeFunction",
        "function_name": "${aws_lambda_function.main.function_name}",
        "principal": "cloudfront.amazonaws.com",
        "source_arn": "${aws_cloudfront_distribution.main.arn}"
      }
    },
    "aws_s3_bucket": {
      "main": {
        "bucket": "${var.bucket_name}"
      }
    },
    "aws_s3_bucket_public_access_block": {
      "main": {
        "bucket": "${aws_s3_bucket.main.id}",
        "block_public_acls": true,
        "block_public_policy": true,
        "ignore_public_acls": true,
        "restrict_public_buckets": true
      }
    },
    "aws_s3_bucket_server_side_encryption_configuration": {
      "main": {
        "bucket": "${aws_s3_bucket.main.id}",
        "rule": {
          "apply_server_side_encryption_by_default": {
            "sse_algorithm": "AES256"
          }
        }
      }
    },
    "aws_s3_bucket_policy": {
      "main": {
        "bucket": "${aws_s3_bucket.main.id}",
        "policy": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Sid\":\"AllowCloudFrontOAC\",\"Effect\":\"Allow\",\"Principal\":{\"Service\":\"cloudfront.amazonaws.com\"},\"Action\":\"s3:GetObject\",\"Resource\":\"${aws_s3_bucket.main.arn}/*\",\"Condition\":{\"StringEquals\":{\"AWS:SourceArn\":\"${aws_cloudfront_distribution.main.arn}\"}}}]}"
      }
    },
    "aws_cloudfront_origin_access_control": {
      "lambda": {
        "name": "${var.project_name}-${var.stage}-lambda-oac",
        "origin_access_control_origin_type": "lambda",
        "signing_behavior": "always",
        "signing_protocol": "sigv4"
      },
      "s3": {
        "name": "${var.project_name}-${var.stage}-s3-oac",
        "origin_access_control_origin_type": "s3",
        "signing_behavior": "always",
        "signing_protocol": "sigv4"
      }
    },
    "aws_cloudfront_distribution": {
      "main": {
        "enabled": true,
        "price_class": "PriceClass_100",
        "default_root_object": "",
        "aliases": "${var.enable_custom_domain ? [local.custom_domain] : []}",
        "origin": [
          {
            "domain_name": "${replace(replace(aws_lambda_function_url.main.function_url, \"https://\", \"\"), \"/\", \"\")}",
            "origin_id": "lambda",
            "origin_access_control_id": "${aws_cloudfront_origin_access_control.lambda.id}",
            "custom_origin_config": {
              "http_port": 80,
              "https_port": 443,
              "origin_protocol_policy": "https-only",
              "origin_ssl_protocols": ["TLSv1.2"]
            }
          },
          {
            "domain_name": "${aws_s3_bucket.main.bucket_regional_domain_name}",
            "origin_id": "s3",
            "origin_access_control_id": "${aws_cloudfront_origin_access_control.s3.id}"
          }
        ],
        "default_cache_behavior": {
          "target_origin_id": "lambda",
          "viewer_protocol_policy": "redirect-to-https",
          "allowed_methods": ["GET", "HEAD", "OPTIONS", "PUT", "POST", "PATCH", "DELETE"],
          "cached_methods": ["GET", "HEAD"],
          "cache_policy_id": "83da9c7e-98b4-4e11-a168-04f0df8e2c65"
        },
        "ordered_cache_behavior": [
          {
            "path_pattern": "/public/*",
            "target_origin_id": "s3",
            "viewer_protocol_policy": "redirect-to-https",
            "allowed_methods": ["GET", "HEAD"],
            "cached_methods": ["GET", "HEAD"],
            "cache_policy_id": "658327ea-f89d-4fab-a63d-7e88639e58f6"
          },
          {
            "path_pattern": "/_gothic/*",
            "target_origin_id": "lambda",
            "viewer_protocol_policy": "redirect-to-https",
            "allowed_methods": ["GET", "HEAD"],
            "cached_methods": ["GET", "HEAD"],
            "cache_policy_id": "658327ea-f89d-4fab-a63d-7e88639e58f6"
          }
        ],
        "restrictions": {
          "geo_restriction": {
            "restriction_type": "none"
          }
        },
        "viewer_certificate": {
          "cloudfront_default_certificate": "${var.enable_custom_domain ? null : true}",
          "acm_certificate_arn": "${var.enable_custom_domain ? (var.enable_managed_cert ? one(aws_acm_certificate_validation.managed[*].certificate_arn) : local.certificate_arn) : null}",
          "ssl_support_method": "${var.enable_custom_domain ? \"sni-only\" : null}",
          "minimum_protocol_version": "${var.enable_custom_domain ? \"TLSv1.2_2021\" : null}"
        }
      }
    },
    "aws_route53_record": {
      "alias": {
        "count": "${var.enable_route53 ? 1 : 0}",
        "zone_id": "${var.enable_route53 ? local.hosted_zone_id : \"placeholder\"}",
        "name": "${var.enable_route53 ? local.custom_domain : \"placeholder.invalid\"}",
        "type": "A",
        "alias": {
          "name": "${aws_cloudfront_distribution.main.domain_name}",
          "zone_id": "${aws_cloudfront_distribution.main.hosted_zone_id}",
          "evaluate_target_health": false
        }
      },
      "cert_validation": {
        "count": "${var.enable_managed_cert ? 1 : 0}",
        "zone_id": "${var.enable_managed_cert ? local.hosted_zone_id : \"placeholder\"}",
        "name": "${var.enable_managed_cert ? tolist(aws_acm_certificate.managed[0].domain_validation_options)[0].resource_record_name : \"\"}",
        "type": "${var.enable_managed_cert ? tolist(aws_acm_certificate.managed[0].domain_validation_options)[0].resource_record_type : \"CNAME\"}",
        "records": ["${var.enable_managed_cert ? tolist(aws_acm_certificate.managed[0].domain_validation_options)[0].resource_record_value : \"\"}"],
        "ttl": 60,
        "allow_overwrite": true
      }
    },
    "aws_acm_certificate": {
      "managed": {
        "count": "${var.enable_managed_cert ? 1 : 0}",
        "provider": "aws.us_east_1",
        "domain_name": "${var.enable_managed_cert ? local.custom_domain : \"placeholder.invalid\"}",
        "validation_method": "DNS",
        "lifecycle": {
          "create_before_destroy": true
        }
      }
    },
    "aws_acm_certificate_validation": {
      "managed": {
        "count": "${var.enable_managed_cert ? 1 : 0}",
        "provider": "aws.us_east_1",
        "certificate_arn": "${one(aws_acm_certificate.managed[*].arn)}",
        "validation_record_fqdns": "${aws_route53_record.cert_validation[*].fqdn}"
      }
    },
    "aws_wafv2_web_acl_association": {
      "main": {
        "count": "${var.enable_waf ? 1 : 0}",
        "resource_arn": "${aws_cloudfront_distribution.main.arn}",
        "web_acl_arn": "${local.waf_arn}"
      }
    }
  }
}
